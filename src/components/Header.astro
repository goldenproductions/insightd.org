---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { label: 'Features', href: '#features' },
  { label: 'Screenshots', href: '#screenshots' },
  { label: 'Install', href: '#install' },
  { label: 'FAQ', href: '#faq' },
  { label: 'Docs', href: 'https://docs.insightd.org', external: true },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-bg/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
    <!-- Logo -->
    <a href="/" class="text-lg font-bold text-fg tracking-tight">
      insightd
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 md:flex">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="rounded-lg px-3 py-2 text-sm text-secondary hover:text-fg hover:bg-surface transition-colors"
          {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {link.label}
          {link.external && (
            <svg class="ml-1 -mt-0.5 inline h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          )}
        </a>
      ))}
      <ThemeToggle />
      <a
        href="#install"
        class="ml-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent-dark transition-colors"
      >
        Get Started
      </a>
    </nav>

    <!-- Mobile menu button -->
    <div class="flex items-center gap-2 md:hidden">
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Open menu"
        class="rounded-lg p-2 text-muted hover:text-fg hover:bg-surface transition-colors"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav id="mobile-menu" class="hidden border-t border-border bg-bg md:hidden">
    <div class="mx-auto max-w-6xl space-y-1 px-4 py-3">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="mobile-nav-link block rounded-lg px-3 py-2 text-sm text-secondary hover:text-fg hover:bg-surface transition-colors"
          {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {link.label}
        </a>
      ))}
      <a
        href="#install"
        class="mobile-nav-link mt-2 block rounded-lg bg-accent px-4 py-2 text-center text-sm font-medium text-white hover:bg-accent-dark transition-colors"
      >
        Get Started
      </a>
    </div>
  </nav>
</header>

<script is:inline>
  (function() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');
    let open = false;

    btn.addEventListener('click', function() {
      open = !open;
      menu.classList.toggle('hidden', !open);
      menuIcon.classList.toggle('hidden', open);
      closeIcon.classList.toggle('hidden', !open);
    });

    // Close menu on link click
    document.querySelectorAll('.mobile-nav-link').forEach(function(link) {
      link.addEventListener('click', function() {
        open = false;
        menu.classList.add('hidden');
        menuIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
      });
    });
  })();
</script>
