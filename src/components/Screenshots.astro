---
import BrowserFrame from './BrowserFrame.astro';

const screenshots = [
  { label: 'Container Detail', src: '/screenshots/container_detail_page.png', alt: 'Container detail page showing diagnosis with evidence, related services, and AI analysis' },
  { label: 'Host Detail', src: '/screenshots/Host_detail_page.png', alt: 'Host detail page showing CPU, memory, load, and network charts over 24 hours' },
  { label: 'Container Metrics', src: '/screenshots/container_detail_page_continued.png', alt: 'Container detail page showing CPU, memory, network, and disk I/O charts' },
  { label: 'Insights', src: '/screenshots/insights_page.png', alt: 'Insights page showing availability and health check warnings with feedback buttons' },
];
---

<section id="screenshots" class="py-16 sm:py-20 lg:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-2xl font-bold text-fg sm:text-3xl">See it in action</h2>
      <p class="mt-3 text-secondary">A modern, responsive dashboard designed for clarity.</p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      {screenshots.map(shot => (
        <BrowserFrame label={`insightd — ${shot.label}`}>
          <img src={shot.src} alt={shot.alt} class="w-full" loading="lazy" />
        </BrowserFrame>
      ))}
    </div>
  </div>
</section>
