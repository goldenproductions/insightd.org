---
import CommandBlock from './CommandBlock.astro';

const oneLiner = `curl -sSL https://insightd.org/install.sh | bash`;

const manualCmd = `mkdir -p ~/insightd && cd ~/insightd

# Download the Compose file
curl -sSLO https://raw.githubusercontent.com/goldenproductions/insightd/main/docker-compose.hub.yml

# Write a .env with a generated MQTT password
cat > .env <<EOF
INSIGHTD_MQTT_USER=insightd
INSIGHTD_MQTT_PASS=$(openssl rand -hex 24)
INSIGHTD_HOST_ID=hub-server
INSIGHTD_ALLOW_UPDATES=true
INSIGHTD_ALLOW_ACTIONS=true
EOF
chmod 600 .env

docker compose -f docker-compose.hub.yml up -d

# Then open http://your-server:3000 and follow the setup wizard`;

const k8sCmd = `kubectl apply -f https://raw.githubusercontent.com/goldenproductions/insightd/main/agent/k8s/rbac.yaml
kubectl apply -f https://raw.githubusercontent.com/goldenproductions/insightd/main/agent/k8s/daemonset.yaml`;

const pveCmd = `docker run -d --restart unless-stopped \\
  --name insightd-agent-pve \\
  -e INSIGHTD_RUNTIME=proxmox \\
  -e INSIGHTD_HOST_ID=pve-01 \\
  -e INSIGHTD_MQTT_URL=mqtt://your-broker.lan:1883 \\
  -e INSIGHTD_PVE_API_URL=https://pve-01.lan:8006 \\
  -e INSIGHTD_PVE_TOKEN_ID='insightd@pve!agent01' \\
  -e INSIGHTD_PVE_TOKEN_SECRET=YOUR-TOKEN-SECRET \\
  -e INSIGHTD_PVE_NODE=pve-01 \\
  -e INSIGHTD_ALLOW_ACTIONS=true \\
  andreas404/insightd-agent:latest`;
---

<section id="install" class="py-16 sm:py-20 lg:py-20">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:max-w-5xl lg:px-8">
    <div class="text-center">
      <h2 class="text-2xl font-bold text-fg sm:text-3xl">Up and running in one command</h2>
      <p class="mt-3 text-secondary">Three containers on one server. To add a host, you run one more agent — that's the only difference.</p>
      <p class="mt-2 text-xs text-muted">Requires Docker + Compose v2 on Linux (<code class="rounded bg-surface px-1 py-0.5 text-xs">kubectl</code> for the Kubernetes tab).</p>
    </div>

    <!-- Tabs -->
    <div class="mt-10">
      <div class="flex border-b border-border" role="tablist">
        <button
          role="tab"
          aria-selected="true"
          aria-controls="tab-docker"
          class="install-tab border-b-2 border-accent px-4 py-2.5 text-sm font-medium text-fg"
          data-tab="docker"
        >
          Docker
        </button>
        <button
          role="tab"
          aria-selected="false"
          aria-controls="tab-k8s"
          class="install-tab border-b-2 border-transparent px-4 py-2.5 text-sm font-medium text-muted hover:text-secondary"
          data-tab="k8s"
        >
          Kubernetes
        </button>
        <button
          role="tab"
          aria-selected="false"
          aria-controls="tab-pve"
          class="install-tab border-b-2 border-transparent px-4 py-2.5 text-sm font-medium text-muted hover:text-secondary"
          data-tab="pve"
        >
          Proxmox VE
        </button>
      </div>

      <div class="mt-6">
        <div id="tab-docker" class="install-panel" role="tabpanel">
          <CommandBlock code={oneLiner} />
          <p class="mt-4 text-sm text-muted">
            Installs Mosquitto + hub + a local agent with one command. Generates a random MQTT password, runs <code class="rounded bg-surface px-1 py-0.5 text-xs text-secondary">docker compose up</code>, and waits for the hub to come online. Re-running is safe — existing credentials are preserved.
          </p>

          <details class="mt-4 rounded-lg border border-border bg-bg-secondary">
            <summary class="cursor-pointer select-none px-4 py-2.5 text-sm text-secondary hover:text-fg">
              Prefer the manual install commands?
            </summary>
            <div class="border-t border-border px-4 py-3">
              <CommandBlock code={manualCmd} />
              <p class="mt-3 text-xs text-muted">
                The install script is <a href="https://github.com/goldenproductions/insightd.org/blob/main/public/install.sh" class="text-accent hover:text-accent-dark" target="_blank" rel="noopener noreferrer">public on GitHub</a>. Read it before piping to a shell if you'd rather.
              </p>
            </div>
          </details>
        </div>

        <div id="tab-k8s" class="install-panel hidden" role="tabpanel">
          <CommandBlock code={k8sCmd} />
          <p class="mt-4 text-sm text-muted">
            The agent runs as a DaemonSet — one pod per node — reporting to the same hub and Mosquitto broker as your Docker hosts. Edit the manifest to set your MQTT URL first.
          </p>
        </div>

        <div id="tab-pve" class="install-panel hidden" role="tabpanel">
          <CommandBlock code={pveCmd} />
          <p class="mt-4 text-sm text-muted">
            Runs from any guest VM — no install on the hypervisor. Authenticates with a PVE API token. The <a href="https://docs.insightd.org/guides/proxmox/" class="text-accent hover:text-accent-dark" target="_blank" rel="noopener noreferrer">Proxmox VE guide</a> walks through token creation (one <code class="rounded bg-surface px-1 py-0.5 text-xs text-secondary">pveum</code> command) and ACL setup.
          </p>
        </div>
      </div>

      <div class="mt-6 text-center">
        <a
          href="https://docs.insightd.org/guides/quick-start/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center text-sm text-accent hover:text-accent-dark transition-colors"
        >
          Full installation guide
          <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function() {
    var tabs = document.querySelectorAll('.install-tab');
    var panels = document.querySelectorAll('.install-panel');

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var target = tab.getAttribute('data-tab');

        tabs.forEach(function(t) {
          var isActive = t.getAttribute('data-tab') === target;
          t.setAttribute('aria-selected', isActive ? 'true' : 'false');
          t.classList.toggle('border-accent', isActive);
          t.classList.toggle('text-fg', isActive);
          t.classList.toggle('border-transparent', !isActive);
          t.classList.toggle('text-muted', !isActive);
        });

        panels.forEach(function(p) {
          p.classList.toggle('hidden', p.id !== 'tab-' + target);
        });
      });
    });
  })();
</script>
