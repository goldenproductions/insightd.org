---
---

<section class="py-16 sm:py-20 lg:py-28">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:max-w-5xl lg:px-8">
    <div class="text-center">
      <h2 class="text-2xl font-bold text-fg sm:text-3xl lg:text-4xl">Simple architecture</h2>
      <p class="mt-3 text-secondary lg:mt-4 lg:text-lg">Agents collect. The hub thinks. You stay informed.</p>
    </div>

    <div class="mt-10 overflow-x-auto rounded-xl border border-border bg-surface p-6 sm:p-8 lg:mt-14 lg:p-10">
      <!-- Architecture diagram -->
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center sm:gap-3 lg:gap-5">
        <!-- Agents -->
        <div class="flex flex-col items-center gap-2">
          <div class="rounded-lg border border-border bg-bg-secondary px-4 py-2.5 text-center">
            <div class="text-xs font-semibold uppercase tracking-wide text-accent">Agents</div>
            <div class="mt-1 text-xs text-muted">Per host / node</div>
          </div>
          <div class="flex gap-2">
            <span class="rounded-full bg-accent/10 px-2 py-0.5 text-[10px] text-accent">Docker</span>
            <span class="rounded-full bg-accent/10 px-2 py-0.5 text-[10px] text-accent">K8s</span>
          </div>
        </div>

        <!-- Arrow -->
        <div class="flex items-center text-muted">
          <svg class="hidden h-4 w-8 sm:block" fill="none" viewBox="0 0 32 16" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2 8h24m0 0l-6-6m6 6l-6 6" />
          </svg>
          <svg class="h-8 w-4 sm:hidden" fill="none" viewBox="0 0 16 32" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 2v24m0 0l-6-6m6 6l6-6" />
          </svg>
        </div>

        <!-- MQTT -->
        <div class="rounded-lg border border-border bg-bg-secondary px-4 py-2.5 text-center">
          <div class="text-xs font-semibold uppercase tracking-wide text-warning">MQTT</div>
          <div class="mt-1 text-xs text-muted">Mosquitto</div>
        </div>

        <!-- Arrow -->
        <div class="flex items-center text-muted">
          <svg class="hidden h-4 w-8 sm:block" fill="none" viewBox="0 0 32 16" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2 8h24m0 0l-6-6m6 6l-6 6" />
          </svg>
          <svg class="h-8 w-4 sm:hidden" fill="none" viewBox="0 0 16 32" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 2v24m0 0l-6-6m6 6l6-6" />
          </svg>
        </div>

        <!-- Hub -->
        <div class="rounded-lg border border-accent/30 bg-accent/5 px-4 py-2.5 text-center">
          <div class="text-xs font-semibold uppercase tracking-wide text-accent">Hub</div>
          <div class="mt-1 text-xs text-muted">SQLite + Insights</div>
        </div>

        <!-- Arrow -->
        <div class="flex items-center text-muted">
          <svg class="hidden h-4 w-8 sm:block" fill="none" viewBox="0 0 32 16" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2 8h24m0 0l-6-6m6 6l-6 6" />
          </svg>
          <svg class="h-8 w-4 sm:hidden" fill="none" viewBox="0 0 16 32" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 2v24m0 0l-6-6m6 6l6-6" />
          </svg>
        </div>

        <!-- Outputs -->
        <div class="flex flex-col items-center gap-2">
          <div class="rounded-lg border border-border bg-bg-secondary px-4 py-2.5 text-center">
            <div class="text-xs font-semibold uppercase tracking-wide text-info">Outputs</div>
          </div>
          <div class="flex flex-wrap justify-center gap-2">
            <span class="rounded-full bg-info/10 px-2 py-0.5 text-[10px] text-info">Web UI</span>
            <span class="rounded-full bg-info/10 px-2 py-0.5 text-[10px] text-info">Email</span>
            <span class="rounded-full bg-info/10 px-2 py-0.5 text-[10px] text-info">Webhooks</span>
          </div>
        </div>
      </div>

      <p class="mt-6 text-center text-xs text-muted">
        Single-server mode runs everything in one container — no MQTT needed.
      </p>
    </div>
  </div>
</section>
