---
---

<section class="py-16 sm:py-20 lg:py-20">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:max-w-5xl lg:px-8">
    <div class="text-center">
      <h2 class="text-2xl font-bold text-fg sm:text-3xl">Simple architecture</h2>
      <p class="mt-3 text-secondary">Agents collect. The hub thinks. You stay informed.</p>
    </div>

    <div class="mt-10 rounded-xl border border-border bg-surface p-6 sm:p-8">
      <!-- Desktop: horizontal flow -->
      <div class="hidden sm:flex sm:items-start sm:justify-center sm:gap-4 lg:gap-6">
        <!-- Agents -->
        <div class="flex flex-col items-center gap-3">
          <div class="w-32 rounded-xl border border-border bg-bg-secondary py-4 text-center lg:w-36 lg:py-5">
            <svg class="mx-auto h-6 w-6 text-accent lg:h-7 lg:w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z" />
            </svg>
            <div class="mt-2 text-sm font-semibold text-accent lg:text-base">Agents</div>
            <div class="mt-0.5 text-xs text-muted lg:text-sm">Per host / node</div>
          </div>
          <div class="flex gap-2">
            <span class="rounded-full bg-accent/10 px-2.5 py-0.5 text-xs text-accent">Docker</span>
            <span class="rounded-full bg-accent/10 px-2.5 py-0.5 text-xs text-accent">K8s</span>
          </div>
        </div>

        <!-- Arrow -->
        <svg class="mt-10 h-4 w-10 shrink-0 text-muted lg:mt-12 lg:w-14" fill="none" viewBox="0 0 56 16" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2 8h48m0 0l-6-5m6 5l-6 5" />
        </svg>

        <!-- MQTT -->
        <div class="flex flex-col items-center gap-3">
          <div class="w-32 rounded-xl border border-border bg-bg-secondary py-4 text-center lg:w-36 lg:py-5">
            <svg class="mx-auto h-6 w-6 text-warning lg:h-7 lg:w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
            </svg>
            <div class="mt-2 text-sm font-semibold text-warning lg:text-base">MQTT</div>
            <div class="mt-0.5 text-xs text-muted lg:text-sm">Mosquitto</div>
          </div>
        </div>

        <!-- Arrow -->
        <svg class="mt-10 h-4 w-10 shrink-0 text-muted lg:mt-12 lg:w-14" fill="none" viewBox="0 0 56 16" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2 8h48m0 0l-6-5m6 5l-6 5" />
        </svg>

        <!-- Hub -->
        <div class="flex flex-col items-center gap-3">
          <div class="w-32 rounded-xl border border-accent/30 bg-accent/5 py-4 text-center lg:w-36 lg:py-5">
            <svg class="mx-auto h-6 w-6 text-accent lg:h-7 lg:w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
            </svg>
            <div class="mt-2 text-sm font-semibold text-accent lg:text-base">Hub</div>
            <div class="mt-0.5 text-xs text-muted lg:text-sm">SQLite + Insights</div>
          </div>
        </div>

        <!-- Arrow -->
        <svg class="mt-10 h-4 w-10 shrink-0 text-muted lg:mt-12 lg:w-14" fill="none" viewBox="0 0 56 16" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2 8h48m0 0l-6-5m6 5l-6 5" />
        </svg>

        <!-- Outputs -->
        <div class="flex flex-col items-center gap-3">
          <div class="w-32 rounded-xl border border-border bg-bg-secondary py-4 text-center lg:w-36 lg:py-5">
            <svg class="mx-auto h-6 w-6 text-info lg:h-7 lg:w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />
            </svg>
            <div class="mt-2 text-sm font-semibold text-info lg:text-base">Outputs</div>
            <div class="mt-0.5 text-xs text-muted lg:text-sm">&nbsp;</div>
          </div>
          <div class="flex flex-wrap justify-center gap-2">
            <span class="rounded-full bg-info/10 px-2.5 py-0.5 text-xs text-info">Web UI</span>
            <span class="rounded-full bg-info/10 px-2.5 py-0.5 text-xs text-info">Email</span>
            <span class="rounded-full bg-info/10 px-2.5 py-0.5 text-xs text-info">Webhooks</span>
          </div>
        </div>
      </div>

      <!-- Mobile: vertical flow -->
      <div class="flex flex-col items-center gap-3 sm:hidden">
        <div class="rounded-xl border border-border bg-bg-secondary px-6 py-3 text-center">
          <div class="text-sm font-semibold text-accent">Agents</div>
          <div class="mt-0.5 text-xs text-muted">Per host / node</div>
        </div>
        <div class="flex gap-2">
          <span class="rounded-full bg-accent/10 px-2 py-0.5 text-[10px] text-accent">Docker</span>
          <span class="rounded-full bg-accent/10 px-2 py-0.5 text-[10px] text-accent">K8s</span>
        </div>
        <svg class="h-6 w-4 text-muted" fill="none" viewBox="0 0 16 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 2v18m0 0l-5-5m5 5l5-5" />
        </svg>
        <div class="rounded-xl border border-border bg-bg-secondary px-6 py-3 text-center">
          <div class="text-sm font-semibold text-warning">MQTT</div>
          <div class="mt-0.5 text-xs text-muted">Mosquitto</div>
        </div>
        <svg class="h-6 w-4 text-muted" fill="none" viewBox="0 0 16 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 2v18m0 0l-5-5m5 5l5-5" />
        </svg>
        <div class="rounded-xl border border-accent/30 bg-accent/5 px-6 py-3 text-center">
          <div class="text-sm font-semibold text-accent">Hub</div>
          <div class="mt-0.5 text-xs text-muted">SQLite + Insights</div>
        </div>
        <svg class="h-6 w-4 text-muted" fill="none" viewBox="0 0 16 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 2v18m0 0l-5-5m5 5l5-5" />
        </svg>
        <div class="rounded-xl border border-border bg-bg-secondary px-6 py-3 text-center">
          <div class="text-sm font-semibold text-info">Outputs</div>
        </div>
        <div class="flex flex-wrap justify-center gap-2">
          <span class="rounded-full bg-info/10 px-2 py-0.5 text-[10px] text-info">Web UI</span>
          <span class="rounded-full bg-info/10 px-2 py-0.5 text-[10px] text-info">Email</span>
          <span class="rounded-full bg-info/10 px-2 py-0.5 text-[10px] text-info">Webhooks</span>
        </div>
      </div>

      <p class="mt-6 text-center text-xs text-muted sm:text-sm">
        Single-server mode runs everything in one container — no MQTT needed.
      </p>
    </div>
  </div>
</section>
