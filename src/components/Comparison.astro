---
const rows = [
  {
    tool: 'Grafana + Prometheus',
    insightd: 'Full monitoring without the config overhead. No PromQL, no dashboards to build, no YAML tuning.',
  },
  {
    tool: 'Uptime Kuma',
    insightd: 'Goes beyond HTTP. Monitors containers, hosts, disks, and explains why things are broken.',
  },
  {
    tool: 'Portainer',
    insightd: 'Monitoring-first, not management-first. Health scores, baselines, and predictive insights — not just container status.',
  },
];
---

<section class="py-16 sm:py-20 lg:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-2xl font-bold text-fg sm:text-3xl">How insightd compares</h2>
      <p class="mt-3 text-secondary">The right tool for the homelab sweet spot.</p>
    </div>

    <div class="mt-10 space-y-4 lg:grid lg:grid-cols-3 lg:gap-4 lg:space-y-0">
      {rows.map(row => (
        <div class="rounded-xl border border-border bg-surface p-5">
          <div class="text-sm font-semibold text-fg">vs {row.tool}</div>
          <p class="mt-1.5 text-sm text-muted leading-relaxed">{row.insightd}</p>
        </div>
      ))}
    </div>
  </div>
</section>
