---
import BrowserFrame from './BrowserFrame.astro';
---

<section class="relative overflow-hidden pt-28 pb-16 sm:pt-36 sm:pb-24 lg:pt-44 lg:pb-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h1 class="text-4xl font-bold tracking-tight text-fg sm:text-5xl lg:text-7xl">
        Server awareness<br />
        <span class="text-accent">without the overhead</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-secondary sm:text-xl lg:mt-8 lg:max-w-3xl lg:text-2xl">
        Self-hosted monitoring for Docker containers, hosts, and HTTP endpoints
        across multiple servers. Smart insights, not noisy dashboards.
      </p>

      <!-- CTAs -->
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4 lg:mt-10 lg:gap-5">
        <a
          href="#install"
          class="inline-flex items-center rounded-lg bg-accent px-6 py-3 text-sm font-medium text-white shadow-sm hover:bg-accent-dark transition-colors lg:px-8 lg:py-3.5 lg:text-base"
        >
          Get Started
          <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
        <a
          href="https://github.com/goldenproductions/insightd"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-lg border border-border px-6 py-3 text-sm font-medium text-secondary hover:text-fg hover:border-fg/20 transition-colors lg:px-8 lg:py-3.5 lg:text-base"
        >
          <svg class="mr-2 h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <!-- Badges -->
      <div class="mt-6 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-xs text-muted lg:mt-8 lg:gap-x-6 lg:text-sm">
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-success" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          MIT Licensed
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-success" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          Self-hosted
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-success" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          Zero cloud dependency
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-success" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          No telemetry
        </span>
      </div>
    </div>

    <!-- Dashboard preview -->
    <div class="mx-auto mt-12 max-w-5xl lg:mt-16">
      <BrowserFrame label="insightd — Dashboard">
        <div class="flex aspect-video items-center justify-center bg-gradient-to-br from-[#0f172a] to-[#1e293b] p-8">
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-accent/10">
              <svg class="h-8 w-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />
              </svg>
            </div>
            <p class="text-sm text-muted">Dashboard preview coming soon</p>
          </div>
        </div>
      </BrowserFrame>
    </div>
  </div>

  <!-- Background decoration -->
  <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-40 right-0 h-[500px] w-[500px] rounded-full bg-accent/5 blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 h-[400px] w-[400px] rounded-full bg-accent/3 blur-3xl"></div>
  </div>
</section>
