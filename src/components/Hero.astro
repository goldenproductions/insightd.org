---
import BrowserFrame from './BrowserFrame.astro';
---

<section class="relative overflow-hidden pt-28 pb-16 sm:pt-32 sm:pb-20 lg:pt-36 lg:pb-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h1 class="text-4xl font-bold tracking-tight text-fg sm:text-5xl lg:text-[3.5rem]">
        Server awareness<br />
        <span class="text-accent">without the overhead</span>
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-secondary sm:text-xl lg:max-w-3xl lg:text-xl">
        Self-hosted monitoring for Docker, Kubernetes, and HTTP endpoints
        across multiple servers. Smart insights, not noisy dashboards.
      </p>

      <!-- CTAs -->
      <div class="mt-7 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
        <a
          href="#install"
          class="inline-flex items-center rounded-lg bg-accent px-6 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-accent-dark transition-colors"
        >
          Get Started
          <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
        <a
          href="https://github.com/goldenproductions/insightd"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-lg border border-border px-6 py-2.5 text-sm font-medium text-secondary hover:text-fg hover:border-fg/20 transition-colors"
        >
          <svg class="mr-2 h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <!-- Badges -->
      <div class="mt-5 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-xs text-muted">
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-success" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          MIT Licensed
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-success" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          Self-hosted
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-success" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          Zero cloud dependency
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-success" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          No telemetry
        </span>
      </div>
    </div>

    <!-- Dashboard preview -->
    <div class="mx-auto mt-10 max-w-5xl lg:mt-12">
      <BrowserFrame label="insightd — Dashboard">
        <div class="hero-zoom relative">
          <img
            src="/screenshots/Dashboard.png"
            alt="insightd dashboard showing health score, status bar, attention feed, and insights"
            class="hero-zoom-img block w-full"
            loading="eager"
            decoding="async"
          />
          <div class="hero-zoom-lens" aria-hidden="true"></div>
          <div class="hero-zoom-hint" aria-hidden="true">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="7" />
              <path stroke-linecap="round" d="m20 20-3.5-3.5" />
            </svg>
            <span>Hover to zoom</span>
          </div>
        </div>
      </BrowserFrame>
    </div>
  </div>

  <!-- Background decoration -->
  <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-40 right-0 h-[500px] w-[500px] rounded-full bg-accent/5 blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 h-[400px] w-[400px] rounded-full bg-accent/3 blur-3xl"></div>
  </div>
</section>

<style>
  .hero-zoom { cursor: zoom-in; }

  .hero-zoom-lens {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: none;
    width: 360px;
    height: 360px;
    border-radius: 9999px;
    border: 2px solid rgba(255, 255, 255, 0.7);
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.35),
      inset 0 0 0 1px rgba(255, 255, 255, 0.25),
      0 12px 32px rgba(0, 0, 0, 0.35);
    background-image: url('/screenshots/Dashboard.png');
    background-repeat: no-repeat;
    background-color: var(--color-surface);
    opacity: 0;
    transition: opacity 120ms ease;
    will-change: transform, background-position;
  }
  .hero-zoom.is-zooming .hero-zoom-lens { opacity: 1; }
  .hero-zoom.is-zooming { cursor: none; }

  .hero-zoom-hint {
    position: absolute;
    bottom: 10px;
    right: 10px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border-radius: 9999px;
    background: rgba(15, 23, 42, 0.7);
    color: rgba(255, 255, 255, 0.9);
    font-size: 11px;
    font-weight: 500;
    backdrop-filter: blur(6px);
    pointer-events: none;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 160ms ease, transform 160ms ease;
  }
  .hero-zoom:hover .hero-zoom-hint {
    opacity: 1;
    transform: translateY(0);
  }
  .hero-zoom.is-zooming .hero-zoom-hint { opacity: 0; }

  @media (hover: none) {
    .hero-zoom { cursor: default; }
    .hero-zoom-lens, .hero-zoom-hint { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-zoom-lens, .hero-zoom-hint { transition: none; }
  }
</style>

<script is:inline>
  (function () {
    if (!window.matchMedia('(hover: hover)').matches) return;
    var container = document.querySelector('.hero-zoom');
    if (!container) return;
    var img = container.querySelector('.hero-zoom-img');
    var lens = container.querySelector('.hero-zoom-lens');
    var lensSize = 360;
    var zoom = 2.5;

    function update(e) {
      var rect = img.getBoundingClientRect();
      var x = e.clientX - rect.left;
      var y = e.clientY - rect.top;
      if (x < 0 || y < 0 || x > rect.width || y > rect.height) {
        container.classList.remove('is-zooming');
        return;
      }
      container.classList.add('is-zooming');
      var bgW = rect.width * zoom;
      var bgH = rect.height * zoom;
      lens.style.backgroundSize = bgW + 'px ' + bgH + 'px';
      lens.style.backgroundPosition =
        -(x * zoom - lensSize / 2) + 'px ' +
        -(y * zoom - lensSize / 2) + 'px';
      lens.style.transform =
        'translate(' + (x - lensSize / 2) + 'px,' + (y - lensSize / 2) + 'px)';
    }

    container.addEventListener('mousemove', update);
    container.addEventListener('mouseleave', function () {
      container.classList.remove('is-zooming');
    });
  })();
</script>
